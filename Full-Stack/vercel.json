{
  "version": 2,
  "builds": [
    {
      "src": "Front-End/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "Back-end/api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "source": "/api/(.*)",
      "destination": "Back-end/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "Front-End/$1"
    }
  ]
}